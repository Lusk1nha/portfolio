VITE_GITHUB_TOKEN=your_github_token_here

# Resend (contact form) — https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=Portfolio Contact <contact@yourdomain.com>

# Upstash Redis (rate limiting) — https://console.upstash.com
# Create a free Redis database and copy the REST URL and token
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here
